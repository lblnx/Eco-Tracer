# ── Cloudflare ────────────────────────────────────────────────────────────────
# Token de API con permisos: Account D1 (Edit), Cloudflare Pages (Edit)
# Generar en: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ID de tu cuenta de Cloudflare
# Encontrar en: https://dash.cloudflare.com → barra lateral derecha
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ID de la base de datos D1 (obtenido con: wrangler d1 create dressflow-db)
D1_DATABASE_ID=your_d1_database_id_here

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Clave secreta para firmar/verificar tokens JWT
# PRODUCCIÓN: usar mínimo 64 caracteres aleatorios
# Generar: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-secret-minimum-64-chars

# Duración del token JWT (en segundos)
# 3600 = 1 hora | 86400 = 24 horas | 604800 = 7 días
JWT_EXPIRY_SECONDS=86400

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=DressFlow
APP_VERSION=1.0.0
APP_ENV=development

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000

# ── Configuración de impuestos ────────────────────────────────────────────────
# Porcentaje de IVA (México: 16%)
TAX_RATE=0.16

# ── Docker (solo para entorno local con docker-compose) ───────────────────────
COMPOSE_PROJECT_NAME=dressflow
DOCKER_PORT=8787
