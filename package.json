{
  "name": "dressflow",
  "version": "1.0.0",
  "description": "Sistema de gestión para tienda de vestidos — Cloudflare Pages + D1",
  "private": true,
  "author": "DressFlow Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },

  "scripts": {
    "dev":          "wrangler pages dev src/ --port 8787 --local",
    "deploy":       "wrangler pages deploy src/ --project-name=dressflow",
    "deploy:staging":"wrangler pages deploy src/ --project-name=dressflow --branch=staging",

    "db:create":    "wrangler d1 create dressflow-db",
    "db:migrate":   "wrangler d1 migrations apply dressflow-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply dressflow-db --local",
    "db:studio":    "wrangler d1 execute dressflow-db --local --command='SELECT * FROM users LIMIT 5'",

    "test":         "jest",
    "test:watch":   "jest --watchAll",
    "test:coverage":"jest --coverage --watchAll=false",
    "test:ci":      "jest --coverage --watchAll=false --ci --forceExit",

    "lint":         "eslint src/ --ext .js,.html",
    "lint:fix":     "eslint src/ --ext .js,.html --fix",
    "format":       "prettier --write 'src/**/*.{js,html,json}'",
    "format:check": "prettier --check 'src/**/*.{js,html,json}'",

    "validate":     "npm run lint && npm run test:ci",
    "precommit":    "npm run lint && npm run test"
  },

  "dependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "itty-router": "^5.0.17"
  },

  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.29",
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "jest-environment-miniflare": "^2.14.4",
    "prettier": "^3.3.3",
    "wrangler": "^3.85.0"
  },

  "jest": {
    "testEnvironment": "miniflare",
    "testEnvironmentOptions": {
      "d1Databases": ["DB"],
      "bindings": {
        "JWT_SECRET": "test-secret-jest",
        "APP_NAME": "DressFlow",
        "APP_ENV": "test"
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.min.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches":   70,
        "functions":  75,
        "lines":      75,
        "statements": 75
      }
    },
    "coverageReporters": ["text", "lcov", "html"],
    "coverageDirectory": "coverage"
  },

  "eslintConfig": {
    "env": {
      "es2022": true,
      "worker": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console":       "warn",
      "no-unused-vars":   "error",
      "prefer-const":     "error",
      "no-var":           "error",
      "eqeqeq":           "error",
      "curly":            "error"
    }
  },

  "prettier": {
    "semi":           true,
    "singleQuote":    true,
    "tabWidth":       2,
    "trailingComma":  "es5",
    "printWidth":     100
  }
}